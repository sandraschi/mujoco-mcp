{
  "manifest_version": "0.3",
  "name": "mujoco-mcp",
  "version": "0.2.0",
  "description": "General-purpose MuJoCo physics simulation via MCP",
  "author": { "name": "Sandra Schipal", "url": "https://github.com/sandraschi" },
  "repository": { "type": "git", "url": "https://github.com/sandraschi/mujoco-mcp.git" },
  "homepage": "https://github.com/sandraschi/mujoco-mcp",
  "license": "Apache 2.0",
  "keywords": ["mcp", "model-context-protocol", "fastmcp", "mujoco", "physics", "simulation"],
  "server": {
    "type": "python",
    "entry_point": "src/mujoco_mcp/server.py",
    "mcp_config": {
      "command": "python",
      "args": ["-m", "mujoco_mcp"],
      "env": { "PYTHONPATH": "${__dirname}/src", "PYTHONUNBUFFERED": "1" }
    }
  }
}
